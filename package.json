{
  "name": "zarur-cup",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "lint:rtl": "! grep -REn '\\b(p|m|border|rounded)[lr]-|\\btext-(left|right)\\b|\\b(left|right)-(\\[|[0-9])|\\bflex-row-reverse\\b|style=\\{\\{[^}]*\\b(left|right)\\s*:' src/ messages/ || (echo 'FND-03 violation: physical-direction Tailwind utility OR inline style with left/right found' && exit 1)",
    "lint:tailwind-v4": "! grep -REn '\\[--zc-' src/ || (echo 'Tailwind v4 violation: bare CSS-var shorthand. Use [var(--zc-X)] not [--zc-X]' && exit 1)",
    "db:types": "supabase gen types typescript --linked > src/types/supabase.ts",
    "db:reset": "supabase db reset --linked",
    "db:push": "supabase db push --linked",
    "db:link": "supabase link --project-ref \"$SUPABASE_PROJECT_REF\"",
    "verify:rls": "bash scripts/verify-rls-no-leak.sh",
    "verify:heartbeat": "bash scripts/verify-heartbeat.sh",
    "seed:build": "tsx scripts/build-seed-sql.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:resolve-fixture": "node --test --import tsx tests/score-fetch/*.test.ts",
    "db:test-seed": "psql \"$DATABASE_URL\" -f data/test-fixtures.sql",
    "db:test-clean": "psql \"$DATABASE_URL\" -f data/test-fixtures-clean.sql",
    "prepare": "husky"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.0",
    "clsx": "^2.1.1",
    "next": "15.5.18",
    "next-intl": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "husky": "^9.1.7",
    "supabase": "^2.0.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "ws": "^8.21.0"
  }
}
