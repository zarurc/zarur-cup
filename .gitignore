# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*.local
.env
!.env.example

# generated supabase types — committed so Vercel can build without DB access.
# Regenerate locally via `npm run db:types` after schema changes.

# vercel
.vercel
.vercel/

# supabase
supabase/.branches/
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts
.dev/

# boost (per-machine T&C acceptance — not shared)
.boost/

# Playwright (Phase 2)
/test-results/
/playwright-report/
/playwright/.cache/
/playwright/.auth/
# admin storageState — minted out-of-band via scripts/db-mint-admin-session.cjs,
# contains a session cookie + JWT for the bootstrap admin; never commit.
tests/e2e/.admin-storage-state.json

# Claude PR-bot workflow scratch files (consumed by CI runs, never artifacts)
/plan.md
/debug-notes.md
/review-context.json
/review-report.json
/verify-report.json
/critic-verdict.json
/pr-diff.patch
